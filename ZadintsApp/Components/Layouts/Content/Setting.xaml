<Page x:Class="Zrutas.UI.Views.Frames.Setting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Zrutas.UI.Views.Frames"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="1020"
      Title="Setting">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Settin 2-->
        <Label 
            x:Name="lblTitleGlobal" 
            Content="Configuración" 
            HorizontalAlignment="Left" 
            Margin="17,0,0,0" 
            VerticalAlignment="Top" 
            AutomationProperties.Name="" 
            AutomationProperties.HelpText="" 
            Foreground="{DynamicResource FontColor}" 
            FontSize="25" 
            FontWeight="Bold"/>

        <GroupBox 
            x:Name="gbxSettingTeme_Copiar" 
            Header="" 
            Grid.Row="0"
            BorderThickness="0"
            Margin="17,58,498,838"
            Background="Transparent"
            Padding="0"
      
            AutomationProperties.Name="gbxHotbar">

            <GroupBox.Template>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Border CornerRadius="15"
                BorderBrush="Transparent"
                BorderThickness="2"
                Background="{DynamicResource BackgroundContent1}"
                Effect="{DynamicResource ShadowStyle2}"
                Height="80">
                        <ContentPresenter
                    ContentSource="Content"/>
                    </Border>
                </ControlTemplate>
            </GroupBox.Template>
        </GroupBox>
        
        <Label 
            x:Name="lblTemeSettingLore1" 
            Content="Cambia el tema oscuro o claro de la aplicación." 
            AutomationProperties.Name="" 
            AutomationProperties.HelpText="" 
            Foreground="{DynamicResource FontColor}" 
            FontSize="15" 
            FontWeight="Light" 
            Height="30" 
            IsEnabled="False" HorizontalContentAlignment="Left" Margin="31,92,671,854"/>
        <Label 
            x:Name="lblTemeSetting_Copiar1" 
            Content="Modo de color" 
            HorizontalAlignment="Left" 
            Margin="31,68,0,0" 
            VerticalAlignment="Top" 
            AutomationProperties.Name="" 
            AutomationProperties.HelpText="" 
            Foreground="{DynamicResource FontColor}" 
            FontSize="15" 
            FontWeight="Bold" 
            Height="30" 
            Width="408" 
            IsEnabled="False" HorizontalContentAlignment="Left"/>

        <Button x:Name="btnTeme" 
Content="Cambiar Tema" 
Height="29"
Foreground="{DynamicResource FontColor}"
FontSize="14.5"
FontWeight="SemiBold" 
Width="114" Click="btnTeme_Click" Margin="382,83,524,864">

            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">

                    <Border x:Name="bd"
            Background="{DynamicResource BackgroundContentHover}"
            CornerRadius="6">

                        <ContentPresenter HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd"
                    Property="Background"
                    Value="{DynamicResource BackgroundButtonHover}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Page>
