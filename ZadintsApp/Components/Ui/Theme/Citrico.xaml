<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!--======================================[ DARK COLORS ]====================================-->

    <Color x:Key="DarkBackground1">#FBE4B9</Color>
    <Color x:Key="DarkBackground2">#FCEDE6</Color>
    
    <Color x:Key="DarkBackgroundMargin">#DDE1EA</Color>

    <Color x:Key="DarkBackgroundTab1">#00F5D7A0</Color>
    <Color x:Key="DarkBackgroundTab2">#70FBF4E6 </Color>

    <Color x:Key="DarkContent1">#FCEDE6</Color>
    <Color x:Key="DarkContent2">#F3F4F8</Color>
    <Color x:Key="DarkContent3">#FCEDE6</Color>
    <Color x:Key="DarkContentHover">#F3D292</Color>

    <Color x:Key="ComboBoxTemeBackground">#FFFFFF</Color>
    <Color x:Key="ComboBoxTemeMargin">#B0B3BB</Color>

    <Color x:Key="DarkShadow">#55000000</Color>

    <Color x:Key="DarkButtons">#1A2D36</Color>
    <Color x:Key="DarkButtonsHover">#F7AA23</Color>

    <Color x:Key="SidebarButtonHover">#F7AA23</Color>
    <Color x:Key="SidebarButtonNormal">#8C8E97</Color>
    <Color x:Key="SidebarLine">#C9CDD6</Color>

    <Color x:Key="TabButtonHover">#F5C25F</Color>
    <Color x:Key="TabButtonNormal">#8C8E97</Color>

    <Color x:Key="FontColors">#1E1E2A</Color>
    <Color x:Key="FotterFontColor">#6A6F85</Color>

   

    <SolidColorBrush x:Key="Background1" Color="{StaticResource DarkBackground1}"/>
    <SolidColorBrush x:Key="Background2" Color="{StaticResource DarkBackground2}"/>

    <Color x:Key="DarkBackgroundHover">#F8E4C0</Color>
    <SolidColorBrush x:Key="BackgroundButtonHover" Color="{StaticResource DarkBackgroundHover}"/>
    
    <SolidColorBrush x:Key="BackgroundMargin" Color="{StaticResource DarkBackgroundMargin}"/>

    <SolidColorBrush x:Key="BackgroundTab1" Color="{StaticResource DarkBackgroundTab1}"/>
    <SolidColorBrush x:Key="BackgroundTab2" Color="{StaticResource DarkBackgroundTab2}"/>

    <SolidColorBrush x:Key="BackgroundContent1" Color="{StaticResource DarkContent1}"/>
    <SolidColorBrush x:Key="BackgroundContent2" Color="{StaticResource DarkContent2}"/>
    <SolidColorBrush x:Key="BackgroundContent3" Color="{StaticResource DarkContent3}"/>
    <SolidColorBrush x:Key="BackgroundContentHover" Color="{StaticResource DarkContentHover}"/>

    <SolidColorBrush x:Key="ContentShadow" Color="{StaticResource DarkShadow}"/>

    <SolidColorBrush x:Key="ButtonsColor" Color="{StaticResource DarkButtons}"/>
    <SolidColorBrush x:Key="ButtonsHover" Color="{StaticResource DarkButtonsHover}"/>

    <SolidColorBrush x:Key="CmbTemeBackground" Color="{StaticResource ComboBoxTemeBackground}"/>
    <SolidColorBrush x:Key="CmbTemeMargin" Color="{StaticResource ComboBoxTemeMargin}"/>

    <SolidColorBrush x:Key="FontColor" Color="{StaticResource FontColors}"/>
    <SolidColorBrush x:Key="FontColorFotter" Color="{StaticResource FotterFontColor}"/>

    <SolidColorBrush x:Key="SidebarBtnHover" Color="{StaticResource SidebarButtonHover}"/>
    <SolidColorBrush x:Key="SidebarBtnNormal" Color="{StaticResource SidebarButtonNormal}"/>
    <SolidColorBrush x:Key="SidebarLn" Color="{StaticResource SidebarLine}"/>

    <SolidColorBrush x:Key="TabBtnNormal" Color="{StaticResource TabButtonNormal}"/>
    <SolidColorBrush x:Key="TabBtnHover" Color="{StaticResource TabButtonHover}"/>


    <Color x:Key="IconColor">white</Color>
    <SolidColorBrush x:Key="IconAppColor" Color="{StaticResource IconColor}"/>
    <!--======================================[ DARK COMPONENTS ]====================================-->

    <LinearGradientBrush x:Key="BorderGradientBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <LinearGradientBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterX="0.5" CenterY="0.5"/>
                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                <RotateTransform Angle="51.71" CenterX="0.5" CenterY="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Color="{StaticResource DarkBackground1}" Offset="1"/>
        <GradientStop Color="{StaticResource DarkBackground2}" Offset="0"/>
    </LinearGradientBrush>



    <LinearGradientBrush x:Key="IconAppBackground" StartPoint="0.5,0" EndPoint="0.5,1">
        <LinearGradientBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterX="0.5" CenterY="0.5"/>
                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                <RotateTransform Angle="51.71" CenterX="0.5" CenterY="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Color="{DynamicResource Citricos1}" Offset="1"/>
        <GradientStop Color="{DynamicResource Citricos2}" Offset="0"/>
    </LinearGradientBrush>
    
    
    

    <LinearGradientBrush x:Key="gbxTabColor" StartPoint="0.5,0" EndPoint="0.5,1">
        <LinearGradientBrush.RelativeTransform>
            <TransformGroup>
                <ScaleTransform CenterX="0.5" CenterY="0.5"/>
                <SkewTransform CenterX="0.5" CenterY="0.5"/>
                <RotateTransform Angle="270" CenterX="0.5" CenterY="0.5"/>
                <TranslateTransform/>
            </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Color="{StaticResource DarkBackgroundTab1}" Offset="0"/>
        <GradientStop Color="{StaticResource DarkBackgroundTab2}" Offset="1"/>
    </LinearGradientBrush>



    <ControlTemplate x:Key="SidebarTemplate"
                     TargetType="Button">
        <Border Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}"
        CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center"
  VerticalAlignment="Center"/>
        </Border>
    </ControlTemplate>

    <DropShadowEffect x:Key="ShadowStyle1"
        ShadowDepth="0" 
        Opacity="0.6" 
        Color="{StaticResource DarkShadow}" 
        BlurRadius="10"/>
    
    <DropShadowEffect x:Key="ShadowStyle2"
        Color="{StaticResource DarkShadow}"
        ShadowDepth="3"
        BlurRadius="5"
        Opacity="0.4"/>
    <DropShadowEffect x:Key="ShadowStyle3"
        Color="{StaticResource DarkShadow}"
        ShadowDepth="1"
        BlurRadius="3"
        Opacity="0.2"/>
</ResourceDictionary>